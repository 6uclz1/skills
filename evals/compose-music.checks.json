{
  "global_checks": [
    {
      "id": "no_fake_browser_paths",
      "description": "Browser targets must be search queries or placeholders, not hard-coded Ableton paths.",
      "type": "absence_regex",
      "pattern": "(?:^|\\s)(?:file:|~|/|\\./|\\.\\./|[A-Za-z]:\\\\|\\S+/\\S+\\.(?:adg|adv|als|wav|aif|aiff|mp3|mid|midi|alp)\\b)"
    },
    {
      "id": "no_command_catalog_duplication",
      "description": "Ableton handoff should not paste the full ableton-cli command catalog.",
      "type": "max_regex_count",
      "pattern": "uv run ableton-cli",
      "max": 4
    },
    {
      "id": "kick_bass_relationship_when_present",
      "description": "Outputs mentioning both kick and bass must describe their relationship.",
      "type": "conditional_keywords",
      "when_all": ["kick", "bass"],
      "any": ["composite", "gap", "sidechain", "offbeat", "duration", "register", "low-end", "low end", "mask", "avoid", "double", "answer", "intentional_overlap"]
    }
  ],
  "prompt_checks": {
    "test-01": [
      {"id": "d_dorian", "type": "all_keywords", "keywords": ["D", "dorian"]},
      {"id": "drum_grid", "type": "any_keywords", "keywords": ["grid", "16-step", "32-step"]},
      {"id": "ableton_spec", "type": "requires_composition_spec"}
    ],
    "test-02": [
