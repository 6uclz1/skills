{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/compose-music/composition_spec.schema.json",
  "title": "compose-music composition_spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "brief", "tracks", "sections", "handoff", "finish_criteria"],
  "properties": {
    "version": {
      "const": "1.0"
    },
    "brief": {
      "$ref": "#/$defs/brief"
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/track"
      }
    },
    "sample_assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sample_asset"
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    },
    "handoff": {
      "$ref": "#/$defs/handoff"
    },
    "finish_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "brief": {
      "type": "object",
      "additionalProperties": true,
      "required": ["genre", "bpm", "meter", "key", "mode", "length_bars", "creative_constraint"],
      "properties": {
        "genre": {
          "type": "string",
          "minLength": 1
        },
        "bpm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "meter": {
          "const": "4/4"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        },
        "length_bars": {
          "type": "integer",
          "minimum": 1
        },
        "creative_constraint": {
          "type": "string",
          "minLength": 1
        },
        "genre_traits": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "role", "clip_length_bars", "browser_query", "notes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "clip_length_bars": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "browser_query": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "enum": ["midi", "audio_loop", "sliced_audio"]
        },
        "sample_ref": {
          "type": "string",
          "minLength": 1
        },
        "audio_clip": {
          "$ref": "#/$defs/audio_clip"
        },
        "slice_plan": {
          "$ref": "#/$defs/slice_plan"
        },
        "source_material": {
          "$ref": "#/$defs/source_material"
        },
        "cutup_pattern": {
          "$ref": "#/$defs/cutup_pattern"
        },
        "sound_intent": {
          "type": "string",
          "minLength": 1
        },
        "shape_intent": {
          "type": "string",
          "minLength": 1
        },
        "kick_relationship": {
          "enum": ["avoid", "double", "answer", "intentional_overlap"]
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/note"
          }
        },
        "drum_rows": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timing_feel": {
          "type": "string",
          "minLength": 1
        },
        "swing_amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "humanization": {
          "type": "object",
          "additionalProperties": true
        },
        "polymeter_reset_bar": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sample_asset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "path_ref": {
          "type": "string",
          "minLength": 1
        },
        "root_env": {
          "type": "string",
          "minLength": 1
        },
        "relative_path": {
          "type": "string",
          "minLength": 1
        },
        "original_bpm": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "bars": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "trim": {
          "type": "string",
          "minLength": 1
        },
        "rights_status": {
          "$ref": "#/$defs/rights_status"
        }
      }
    },
    "audio_clip": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "warp": {
          "type": "boolean"
        },
        "warp_mode": {
          "enum": ["beats", "tones", "texture", "re-pitch", "complex", "complex_pro"]
        },
        "loop": {
          "type": "boolean"
        },
        "gain_db": {
          "type": "number"
        },
        "transpose_semitones": {
          "type": "number"
        }
      }
    },
    "slice_plan": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["mode", "slice_count", "start_pad"],
          "properties": {
            "mode": {
              "const": "fixed_grid"
            },
            "slice_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 128
            },
            "start_pad": {
              "type": "integer",
              "minimum": 0,
              "maximum": 127
            },
            "create_trigger_clip": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "max_slices", "start_pad_midi"],
          "properties": {
            "method": {
              "enum": ["transient", "beat", "region", "manual", "slice_count"]
            },
            "resolution": {
              "type": "string",
              "minLength": 1
            },
            "max_slices": {
              "type": "integer",
              "minimum": 1,
              "maximum": 128
            },
            "start_pad_midi": {
              "type": "integer",
              "minimum": 0,
              "maximum": 127
            },
            "create_trigger_clip": {
              "type": "boolean"
            },
            "trigger_clip_slot": {
              "type": "integer",
              "minimum": 0
            },
            "warp_mode": {
              "type": "string",
              "minLength": 1
            },
            "preserve_timing": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "source_material": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "role", "rights_status"],
      "properties": {
        "kind": {
          "enum": ["user_audio_file", "browser_audio", "recorded_audio", "placeholder"]
        },
        "role": {
          "enum": [
            "vocal",
            "melodic_loop",
            "drum_break",
            "texture",
            "field_recording",
            "unknown",
            "vocal_or_melodic_sample",
            "drum_loop_or_break",
            "texture_sample"
          ]
        },
        "path": {
          "type": "string"
        },
        "rights_status": {
          "$ref": "#/$defs/rights_status"
        },
        "source_bpm": {
          "type": ["number", "null"]
        },
        "source_key": {
          "type": ["string", "null"]
        }
      }
    },
    "cutup_pattern": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "unit": {
          "enum": ["1/16", "1/32", "1/8T", "1/16T"]
        },
        "slice_map": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 127
          }
        },
        "motif": {
          "type": "array"
        },
        "pattern": {
          "type": "array"
        },
        "variation_strategy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rights_status": {
      "enum": ["original", "cleared", "royalty_free", "private_test", "unknown"]
    },
    "note": {
      "type": "object",
      "additionalProperties": true,
      "required": ["pitch", "start_time", "duration", "velocity", "mute"],
      "properties": {
        "pitch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "start_time": {
          "type": "number",
          "minimum": 0
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "velocity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127
        },
        "mute": {
          "type": "boolean"
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "start_bar", "length_bars", "density", "active_tracks"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "start_bar": {
          "type": "integer",
          "minimum": 1
        },
        "length_bars": {
          "type": "integer",
          "minimum": 1
        },
        "density": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "active_tracks": {
          "$ref": "#/$defs/track_refs"
        },
        "foreground": {
          "$ref": "#/$defs/track_refs"
        },
        "midground": {
          "$ref": "#/$defs/track_refs"
        },
        "background": {
          "$ref": "#/$defs/track_refs"
        },
        "identity_carrier": {
          "type": "string",
          "minLength": 1
        },
        "move": {
          "type": "string",
          "minLength": 1
        },
        "transition_event": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": true,
      "required": ["requires_browser_search", "browser_queries", "export_target"],
      "properties": {
        "requires_browser_search": {
          "type": "boolean"
        },
        "browser_queries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sample_asset_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "export_target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "track_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
